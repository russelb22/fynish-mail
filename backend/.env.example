FYNISH_APP_ENV=local
FYNISH_DB_MODE=sqlite
FYNISH_DATABASE_URL=sqlite:///backend/data/fynish.sqlite3
FYNISH_POSTGRES_HOST=
FYNISH_POSTGRES_PORT=5432
FYNISH_POSTGRES_DATABASE=
FYNISH_POSTGRES_USER=
FYNISH_POSTGRES_PASSWORD=
FYNISH_CLOUDSQL_INSTANCE_CONNECTION_NAME=
FYNISH_FRONTEND_URL=http://127.0.0.1:5173/
FYNISH_BACKEND_CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,http://localhost:4173,http://127.0.0.1:4173
FYNISH_DATA_DIR=backend/data
FYNISH_SQLITE_DATABASE_PATH=backend/data/fynish.sqlite3
# Local-only OAuth credential files. Supply your own and do not commit them.
FYNISH_GOOGLE_CLIENT_SECRETS_PATH=backend/google-credentials.json
FYNISH_GOOGLE_WEB_CLIENT_SECRETS_PATH=backend/google-credentials.web.json
FYNISH_GOOGLE_WEB_OAUTH_CALLBACK_URL=http://127.0.0.1:5173/auth/gmail/callback
# Local token storage. This directory should remain untracked.
FYNISH_GOOGLE_TOKEN_DIR=backend/data/google_tokens
FYNISH_GMAIL_TOKEN_STORAGE_MODE=auto
FYNISH_ENABLE_GMAIL_WRITES=0
FYNISH_AUTO_SYNC_ENABLED=1
FYNISH_AUTO_SYNC_INTERVAL_SECONDS=300
FYNISH_SCHEDULED_SYNC_ENABLED=0
FYNISH_SCHEDULED_DIGESTS_ENABLED=0
FYNISH_SEED_MOCK_ACCOUNTS=1
FYNISH_MAIL_PROVIDER=disabled
FYNISH_MAIL_FROM_EMAIL=
FYNISH_MAIL_API_KEY=
